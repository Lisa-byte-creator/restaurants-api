{
  "Serilog":{
    "MinimumLevel": {
      "Override": {
        "Microsoft":"Warning",
        "Microsft.EntityFrameworkCore": "Information"

        }
      },
      "WriteTo":[
        {
          "Name": "Console",
          "Args": {

            "outputTemplate": "[{TimeStamp:dd- MMHH:mm:ss} {Level:u3}]|{SourceContext}|{NewLine} {Message:1j}{NewLine}{Exception}"

          }
        },
        {
          "Name": "File",
          "Args": {
            "path": "Logs/Restaurant-API-.log",
            "rollingInterval": "Day",
            "rollOnFileSizeLimit": true,
            "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter,Serilog.Formatting.Compact"
          }
        }
      ]
    }
  }

